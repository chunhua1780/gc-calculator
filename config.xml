<?xml version='1.0' encoding='utf-8'?>
<widget id="com.ghostchat.calculator" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>Calculator</name>
    <description>Calculator app</description>
    <author email="admin@example.com" href="https://example.com">Calculator</author>
    <content src="index.html" />

    <!-- 屏幕方向锁定竖屏 -->
    <preference name="Orientation" value="portrait" />

    <!-- 兼容老设备：不强制要求过高安卓版本 -->
    <preference name="android-minSdkVersion" value="22" />
    <preference name="android-targetSdkVersion" value="34" />
    <preference name="android-compileSdkVersion" value="34" />

    <!-- WebView性能与兼容性 -->
    <preference name="AndroidXEnabled" value="true" />
    <preference name="AndroidInsecureFileModeEnabled" value="true" />
    <preference name="MixedContentMode" value="0" />

    <!-- 启动屏 & 窗口背景：统一计算器品牌色，消除白屏闪烁 -->
    <!-- BackgroundColor 设置 WebView 背景，避免 HTML 加载前出现白屏 (ARGB) -->
    <preference name="BackgroundColor" value="0xffe8e0ff" />
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="SplashScreenDelay" value="500" />
    <preference name="FadeSplashScreen" value="true" />
    <preference name="FadeSplashScreenDuration" value="300" />
    <preference name="ShowSplashScreenSpinner" value="false" />
    <!-- Android 12+ 系统级 SplashScreen API：背景色与计算器界面统一 -->
    <preference name="AndroidWindowSplashScreenBackground" value="#E8E0FF" />
    <preference name="AndroidWindowSplashScreenIconBackgroundColor" value="#E8E0FF" />

    <platform name="android">
        <!-- 图标：标准 PNG 格式，兼容所有 Android 版本 -->
        <!-- 启动画面背景色由 AndroidWindowSplashScreenBackground 统一控制 -->
        <icon density="mdpi"     src="icon192.png" />
        <icon density="hdpi"     src="icon192.png" />
        <icon density="xhdpi"    src="icon192.png" />
        <icon density="xxhdpi"   src="icon512.png" />
        <icon density="xxxhdpi"  src="icon512.png" />

        <!-- Cordova 内置启动屏背景色（cordova-android splashscreen 读取此颜色） -->
        <config-file target="res/values/colors.xml" parent="/resources">
            <color name="cdv_splashscreen_background">#E8E0FF</color>
        </config-file>

        <!-- 应用权限：保活+通知必需
             注意：READ/WRITE_EXTERNAL_STORAGE 不在这里手动声明，
             cordova-plugin-file 插件会自动注入这两个权限，
             手动重复声明会导致 AndroidManifest 合并时报错冲突 -->
        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.INTERNET" />
            <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
            <uses-permission android:name="android.permission.WAKE_LOCK" />
            <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
            <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
            <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
            <uses-permission android:name="android.permission.VIBRATE" />
            <uses-permission android:name="android.permission.CAMERA" />
            <uses-permission android:name="android.permission.RECORD_AUDIO" />
            <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
            <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
            <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
        </config-file>

        <!-- 允许https明文/混合内容，老WebView兼容 -->
        <edit-config target="/manifest/application" file="AndroidManifest.xml" mode="merge">
            <application android:usesCleartextTraffic="true" />
        </edit-config>
    </platform>

    <!-- ═══ 核心：长连接保活插件 ═══ -->
    <!-- 前台服务保活：APP切到后台时保持进程存活，维持Supabase WebSocket连接不断 -->
    <plugin name="cordova-plugin-background-mode" spec="^0.7.3" />

    <!-- 本地通知：收到新消息时弹系统通知，不依赖任何远程推送服务，纯本地触发 -->
    <plugin name="cordova-plugin-local-notification" spec="^1.2.3" />

    <!-- 设备信息：用于区分安卓/鸿蒙环境做兼容判断 -->
    <plugin name="cordova-plugin-device" spec="^3.0.0" />

    <!-- 状态栏 -->
    <plugin name="cordova-plugin-statusbar" spec="^4.0.0" />

    <!-- 文件/相机（聊天功能依赖） -->
    <plugin name="cordova-plugin-camera" spec="^7.0.0" />
    <plugin name="cordova-plugin-file" spec="^8.1.0" />

    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <access origin="*" />
</widget>
